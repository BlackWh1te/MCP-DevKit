{
  "name": "mcp-devkit",
  "version": "1.0.6",
  "description": "One MCP server to rule them all — project intelligence, persistent memory, cross-platform terminal, git tools, and code search. Works on Windows, Mac, and Linux.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-devkit": "dist/index.js",
    "devkit": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"*.{json,md,js,yml,yaml}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"*.{json,md,js,yml,yaml}\"",
    "typecheck": "tsc --noEmit",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "cursor",
    "vscode",
    "claude",
    "developer-tools",
    "project-intelligence",
    "cross-platform",
    "windows"
  ],
  "author": "BlackWh1te",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.10.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "lefthook": "^1.13.6",
    "prettier": "^3.8.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.2",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
